def discretize_selected_features(df, target_col, numerical_cols, n_bins=5, strategy='quantile'):
    """
    Discretize only selected numerical columns
    """
    print(" Performing data discretization (only on selected columns)...")

    df_discretized = df.copy()

    # Check which columns exist in the data
    available_cols = [col for col in numerical_cols if col in df.columns]
    print(f"   Number of columns available for discretization: {len(available_cols)} out of {len(numerical_cols)}")

    if not available_cols:
        print(" None of the specified columns found in the data")
        return df_discretized, {}

    discretization_info = {
        'strategy': strategy,
        'n_bins': n_bins,
        'features_discretized': available_cols,
        'bin_edges': {}
    }

    # Discretize each selected feature
    for feature in available_cols:
        try:
            # Check if column is numeric
            if not np.issubdtype(df[feature].dtype, np.number):
                print(f" Column {feature} is not numeric, skipping")
                continue

            discretizer = KBinsDiscretizer(
                n_bins=n_bins,
                encode='ordinal',
                strategy=strategy
            )

            feature_values = df[[feature]].values
            discretized_values = discretizer.fit_transform(feature_values)

            new_feature_name = f"{feature}_discretized"
            df_discretized[new_feature_name] = discretized_values.astype(int)

            # Remove original feature
            df_discretized = df_discretized.drop(columns=[feature])

            # Store bin edges info
            bin_edges = discretizer.bin_edges_[0]
            discretization_info['bin_edges'][feature] = {
                'original_feature': feature,
                'new_feature_name': new_feature_name,
                'bin_edges': bin_edges.tolist(),
                'bin_ranges': [f"{bin_edges[i]:.2f}-{bin_edges[i + 1]:.2f}"
                               for i in range(len(bin_edges) - 1)],
                'strategy': strategy,
                'n_bins': n_bins
            }

            print(f"   ✓ {feature} discretized → {new_feature_name}")

        except Exception as e:
            print(f"  Error discretizing feature {feature}: {e}")

    print(f" Discretization completed. {len(available_cols)} columns discretized")
    print(f"   Data shape before discretization: {df.shape}")
    print(f"   Data shape after discretization: {df_discretized.shape}")

    return df_discretized, discretization_info


def find_best_model_with_pycaret(X_train, y_train, target_name, experiment_name="pycaret_experiment"):
    """
    Find best model using PyCaret
    """
    print("\n" + "=" * 70)
    print(" Starting modeling with PyCaret")
    print("=" * 70)

    # Combine X_train and y_train
    train_data = X_train.copy()
    train_data[target_name] = y_train

    # Setup PyCaret
    print(" Setting up PyCaret...")

    try:
        clf = setup(
            data=train_data,
            target=target_name,
            train_size=0.8,
            session_id=42,
            verbose=False,
            log_experiment=False,
            experiment_name=experiment_name,
            fold_strategy='stratifiedkfold',
            fold=5,
            use_gpu=False,
            n_jobs=-1,
            remove_multicollinearity=False,
        )

        # Compare models
        print(" Comparing models...")
        compare_result = compare_models(
            fold=5,
            n_select=1,
            verbose=False,
            sort='Accuracy',
            exclude=['qda', 'lda']
        )

        # Display comparison results
        print("\n PyCaret Model Comparison Results:")
        results = pull()
        print(results[['Model', 'Accuracy', 'AUC', 'Recall', 'Prec.', 'F1']].to_string(index=False))

        # Display best model info
        best_model = compare_result
        model_name = type(best_model).__name__
        print(f"\n Best model selected: {model_name}")

        # Create final model
        print(" Training final model...")
        final_model = finalize_model(best_model)

        return final_model, model_name

    except Exception as e:
        print(f" Error in PyCaret: {e}")
        print(" Using default CatBoostClassifier")
        return CatBoostClassifier(random_state=42, verbose=False), "CatBoostClassifier"


def optimize_catboost_with_sklearn_advanced(X_train, y_train, pycaret_accuracy):
