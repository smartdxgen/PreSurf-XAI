        plt.title(f'Comparison of {title} by Surfactant Group', fontsize=12, fontweight='bold')
        plt.ylabel(ylabel)
        plt.xlabel('Surfactant Administration Group')
        plt.grid(True, alpha=0.3)

        # Save plot
        plt.tight_layout()
        plt.savefig(f'Analysis_Results/{var}_Comparison.png', dpi=300, bbox_inches='tight')
        plt.show()

    print(" Visualizations created and saved")


