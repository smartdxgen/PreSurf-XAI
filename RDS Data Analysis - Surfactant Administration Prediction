def create_frequency_table(df):
    """Create frequency table for qualitative variables"""

    print("\n" + "=" * 60)
    print("Frequency Table for Qualitative Variables")
    print("=" * 60)

    target_col = 'Surfactant_Administered'

    # Qualitative variables based on your definition
    qualitative_cols = [
        'Delivery_Mode', 'Maternal_Diabetes', 'Maternal_Education',
        'Maternal_Occupation', 'Treatment_Type', 'Maternal_Blood_Pressure',
        'Substance_Use_Pregnancy', 'PROM', 'Chorioamnionitis',
        'History_Premature_Birth', 'Antenatal_Steroid', 'Amniotic_Fluid',
        'Fetal_Growth', 'Fetal_Distress', 'IVF', 'Multiple_Birth', 'Infant_Gender',
        'Breathing_Condition_Birth', 'Respiratory_Distress', 'Resuscitation_Needed',
        'Oxygen_Therapy', 'CPAP_Needed', 'PPV_Needed', 'Intubation_Needed',
        'Cardiac_Massage_Needed', 'Medication_Given'
    ]

    qualitative_cols = [col for col in qualitative_cols if col in df.columns]

    results = []

    for col in qualitative_cols:
        # Create cross-tabulation
        cross_tab = pd.crosstab(df[col], df[target_col])

        # Ensure all groups are present
        unique_groups = sorted(df[target_col].unique())
        for group_val in unique_groups:
            if group_val not in cross_tab.columns:
                cross_tab[group_val] = 0

        # Order columns
        cross_tab = cross_tab[unique_groups]

        # Calculate percentages
        cross_tab_percent = cross_tab.div(cross_tab.sum(axis=1), axis=0) * 100

        # For each category
        for category in cross_tab.index:
            row = {
                'Variable': col,
                'Category': str(category),
            }

            # Add counts and percentages for each group
            for group_val in unique_groups:
                row[f'Count_{group_val}'] = int(cross_tab.loc[category, group_val])
                row[f'Percent_{group_val}'] = round(cross_tab_percent.loc[category, group_val], 1)

            # Calculate totals
            total_count = int(cross_tab.loc[category].sum())
            row['Total_Count'] = total_count
            row['Total_Percent'] = round((total_count / cross_tab.sum().sum()) * 100, 1)

            results.append(row)

    freq_df = pd.DataFrame(results)

    print(f" Frequency table created: {len(qualitative_cols)} qualitative variables")

    return freq_df


