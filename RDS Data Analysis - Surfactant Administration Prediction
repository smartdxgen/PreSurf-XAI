def create_statistical_table(df):
    """Create statistical analysis table with proper test selection based on normality"""

    print("\n" + "=" * 60)
    print("Statistical Analysis Table (Group Comparisons)")
    print("=" * 60)

    target_col = 'Surfactant_Administered'

    # First, check normality and homogeneity
    normality_results = check_normality_and_homogeneity(df)

    # Quantitative variables for analysis
    quantitative_cols = [
        'Gestational_Age_Weeks', 'Gestational_Age_Days', 'Gestational_Age_Days_total', 'Maternal_Age',
        'Birth_Weight', 'Birth_Height', 'Head_Circumference',
        'Umbilical_pH', 'Base_Excess', 'FiO2'
    ]

    # Only columns that exist
    quantitative_cols = [col for col in quantitative_cols if col in df.columns]

    results = []

    for col in quantitative_cols:
        # Separate data for groups
        groups_data = {}
        unique_groups = sorted(df[target_col].unique())

        for group_val in unique_groups:
            groups_data[group_val] = df[df[target_col] == group_val][col].dropna().values

        # Calculate P-value
        p_value = np.nan
        test_used = "N/A"

        # Get normality and homogeneity info for this variable
        var_normality = normality_results.get(col, {})
        all_normal = var_normality.get('all_normal', False)
        is_homogeneous = var_normality.get('is_homogeneous', False)

        try:
            # Check which groups have data
            groups_with_data = []
            for group_val in unique_groups:
                if len(groups_data[group_val]) > 0:
                    groups_with_data.append(groups_data[group_val])

            if len(groups_with_data) >= 2:
                if len(groups_with_data) == 2:
                    # Two groups: choose test based on normality
                    if all_normal:
                        # Normal data
                        if is_homogeneous:
                            # Equal variances t-test
                            t_stat, p_value = ttest_ind(groups_with_data[0], groups_with_data[1], equal_var=True)
                            test_used = "Independent t-test (normal, equal variances)"
                        else:
                            # Welch's t-test for unequal variances
                            t_stat, p_value = ttest_ind(groups_with_data[0], groups_with_data[1], equal_var=False)
                            test_used = "Welch's t-test (normal, unequal variances)"
                    else:
                        # Non-normal data: Mann-Whitney U test
                        u_stat, p_value = mannwhitneyu(groups_with_data[0], groups_with_data[1])
                        test_used = "Mann-Whitney U test (non-normal)"

                else:
                    # More than two groups
                    if all_normal and is_homogeneous:
                        # Normal and homogeneous: ANOVA
                        f_stat, p_value = f_oneway(*groups_with_data)
                        test_used = "ANOVA (normal, homogeneous variances)"
                    else:
                        # Non-normal or non-homogeneous: Kruskal-Wallis
                        h_stat, p_value = kruskal(*groups_with_data)
                        test_used = "Kruskal-Wallis test (non-normal or non-homogeneous)"

        except Exception as e:
            test_used = f"Calculation Error: {str(e)[:50]}"
            p_value = np.nan

        # Calculate means for each group
        means_data = {}
        for group_val in unique_groups:
            if len(groups_data[group_val]) > 0:
                means_data[f'Mean_{group_val}'] = round(groups_data[group_val].mean(), 2)
                means_data[f'N_{group_val}'] = len(groups_data[group_val])
            else:
                means_data[f'Mean_{group_val}'] = np.nan
                means_data[f'N_{group_val}'] = 0

        # Determine significance
        significant = "No"
        significance_stars = ""
        if not np.isnan(p_value):
            if p_value < 0.001:
                significant = "Yes"
                significance_stars = "***"
            elif p_value < 0.01:
                significant = "Yes"
                significance_stars = "**"
            elif p_value < 0.05:
                significant = "Yes"
                significance_stars = "*"

        # Create result row
        result_row = {
            'Variable': col,
            'Type': 'Quantitative',
            'Normality': 'Normal' if all_normal else 'Non-normal',
            'Test': test_used,
            'P_value': round(p_value, 4) if not np.isnan(p_value) else "N/A",
            'Significant': f"{significant} {significance_stars}".strip(),
        }

        # Add means and counts
        for group_val in unique_groups:
            result_row[f'Mean_{group_val}'] = means_data[f'Mean_{group_val}']
            result_row[f'N_{group_val}'] = means_data[f'N_{group_val}']

        results.append(result_row)

    # Analysis for qualitative (categorical) variables
    qualitative_cols = [
        'Delivery_Mode', 'Maternal_Diabetes', 'Maternal_Education',
        'Maternal_Occupation', 'Treatment_Type', 'Maternal_Blood_Pressure',
        'Substance_Use_Pregnancy', 'PROM', 'Chorioamnionitis',
        'History_Premature_Birth', 'Antenatal_Steroid', 'Amniotic_Fluid',
        'Fetal_Growth', 'Fetal_Distress', 'IVF', 'Multiple_Birth', 'Infant_Gender',
        'Breathing_Condition_Birth', 'Respiratory_Distress', 'Resuscitation_Needed',
        'Oxygen_Therapy', 'CPAP_Needed', 'PPV_Needed', 'Intubation_Needed',
        'Cardiac_Massage_Needed', 'Medication_Given'
    ]

    qualitative_cols = [col for col in qualitative_cols if col in df.columns]

    for col in qualitative_cols:
        # Create contingency table
        contingency = pd.crosstab(df[col], df[target_col])

        # Calculate Chi-square
        p_value = np.nan
        test_used = "N/A"

        try:
            if contingency.shape[0] > 1 and contingency.shape[1] > 1:
                chi2, p_value, dof, expected = chi2_contingency(contingency)
                test_used = "Chi-square"
            elif contingency.shape[0] == 1 or contingency.shape[1] == 1:
                # For single row/column, can't do chi-square
                test_used = "Cannot compute"
                p_value = np.nan
        except:
            test_used = "Calculation Error"
            p_value = np.nan

        # Determine significance
        significant = "No"
        significance_stars = ""
        if not np.isnan(p_value):
            if p_value < 0.001:
                significant = "Yes"
                significance_stars = "***"
            elif p_value < 0.01:
                significant = "Yes"
                significance_stars = "**"
            elif p_value < 0.05:
                significant = "Yes"
                significance_stars = "*"

        # Calculate counts in each group
        counts_data = {}
        for group_val in sorted(df[target_col].unique()):
            counts_data[f'N_{group_val}'] = contingency[group_val].sum() if group_val in contingency.columns else 0

        # Calculate percentages for each category (if only a few categories)
        if len(contingency) <= 5:  # For variables with up to 5 categories
            categories_summary = []
            for idx in contingency.index:
                total_cat = contingency.loc[idx].sum()
                if total_cat > 0:
                    cat_pct = []
                    for group_val in sorted(df[target_col].unique()):
                        count = contingency.loc[idx, group_val] if group_val in contingency.columns else 0
                        pct = (count / total_cat * 100)
                        cat_pct.append(f"{group_val}:{pct:.0f}%")
                    categories_summary.append(f"{idx} ({'; '.join(cat_pct)})")

            categories_str = "; ".join(categories_summary)
        else:
            categories_str = f"{len(contingency)} categories"

        # Create result row
        result_row = {
            'Variable': col,
            'Type': 'Qualitative',
            'Normality': 'N/A',
            'Test': test_used,
            'P_value': round(p_value, 4) if not np.isnan(p_value) else "N/A",
            'Significant': f"{significant} {significance_stars}".strip(),
            'Categories_Summary': categories_str,
        }

        # Add counts for each group
        for group_val in sorted(df[target_col].unique()):
            result_row[f'N_{group_val}'] = counts_data[f'N_{group_val}']
            result_row[f'Mean_{group_val}'] = "N/A"  # Not applicable for qualitative

        results.append(result_row)

    stats_df = pd.DataFrame(results)

    # Sort by P-value
    if 'P_value' in stats_df.columns:
        # Separate rows with numeric P-values
        numeric_p = stats_df[stats_df['P_value'] != "N/A"].copy()
        non_numeric_p = stats_df[stats_df['P_value'] == "N/A"].copy()

        if not numeric_p.empty:
            # Convert P_value to numeric
            numeric_p['P_value_num'] = pd.to_numeric(numeric_p['P_value'])
            numeric_p = numeric_p.sort_values('P_value_num')
            numeric_p = numeric_p.drop(columns=['P_value_num'])

            # Recombine
            stats_df = pd.concat([numeric_p, non_numeric_p])

    print(f"Statistical table created: {len(results)} variables")

    return stats_df


