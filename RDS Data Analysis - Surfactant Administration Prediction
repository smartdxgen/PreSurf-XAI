def save_all_results(target_summary, descriptive_table, stats_table, frequency_table, outlier_summary):
    """Save all results to Excel file"""

    print("\n" + "=" * 60)
    print(" Saving All Results to Excel File")
    print("=" * 60)

    try:
        with pd.ExcelWriter('Complete_Analysis_Results.xlsx') as writer:
            # Target summary
            if target_summary is not None:
                target_summary.to_excel(writer, sheet_name='Target_Summary', index=False)
                print("  ✓ Target summary saved")

            # Descriptive statistics
            if descriptive_table is not None:
                descriptive_table.to_excel(writer, sheet_name='Descriptive_Stats', index=False)
                print("  ✓ Descriptive statistics saved")

            # Statistical analysis
            if stats_table is not None:
                stats_table.to_excel(writer, sheet_name='Statistical_Analysis', index=False)
                print("  ✓ Statistical analysis saved")

            # Frequency table
            if frequency_table is not None:
                frequency_table.to_excel(writer, sheet_name='Frequency_Table', index=False)
                print("  ✓ Frequency table saved")

            # Outlier summary
            if outlier_summary is not None:
                outlier_df = pd.DataFrame(outlier_summary)
                outlier_df.to_excel(writer, sheet_name='Outlier_Summary', index=False)
                print("  ✓ Outlier summary saved")

            # Explanation sheet
            explanation = pd.DataFrame({
                'Sheet': ['Target_Summary', 'Descriptive_Stats', 'Statistical_Analysis', 'Frequency_Table',
                          'Outlier_Summary'],
                'Description': [
                    'Distribution of patients in surfactant groups',
                    'Mean, SD, min, max of quantitative variables',
                    'Statistical test results (P-values) for all variables',
                    'Frequency distribution of qualitative variables',
                    'Summary of detected outliers (not removed)'
                ]
            })
            explanation.to_excel(writer, sheet_name='Sheet_Descriptions', index=False)
            print("  ✓ Sheet descriptions saved")

        print("\n All results saved to 'Complete_Analysis_Results.xlsx'")

    except Exception as e:
        print(f" Error saving file: {e}")


