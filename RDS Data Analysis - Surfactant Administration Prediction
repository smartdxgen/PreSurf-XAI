def analyze_target_column(df):
    """Analyze target column (Surfactant_Administered)"""

    print("\n" + "=" * 60)
    print(" Analyzing Target Column (Surfactant_Administered)")
    print("=" * 60)

    target_col = 'Surfactant_Administered'

    if target_col not in df.columns:
        print(f" Column '{target_col}' not found!")
        print(" Available columns:")
        for col in df.columns:
            print(f"  - {col}")
        return None

    # Show distribution of target column
    target_counts = df[target_col].value_counts().sort_index()
    total_patients = len(df)

    print(f"\n Distribution of patients by surfactant administration:")
    print("-" * 50)

    summary_data = []

    # Calculate exact percentages
    for val in sorted(df[target_col].unique()):
        count = target_counts.get(val, 0)
        percentage = (count / total_patients) * 100

        if val == 0:
            label = "No Surfactant"
        elif val == 1:
            label = "1 Administration"
        elif val == 2:
            label = "2 Administrations"
        else:
            label = f"{val} Administrations"

        print(f"  {label}: {count} patients ({percentage:.1f}%)")
        summary_data.append({
            'Group': label,
            'Count': count,
            'Percentage': round(percentage, 1)
        })

    # Verify total
    print(f"\n Total patients: {total_patients}")
    print(f" Calculated percentage sum: {sum([d['Percentage'] for d in summary_data]):.1f}%")

    # Create summary table
    summary_df = pd.DataFrame(summary_data)
    summary_df.loc['Total'] = ['Total', total_patients, 100.0]

    return summary_df, total_patients


