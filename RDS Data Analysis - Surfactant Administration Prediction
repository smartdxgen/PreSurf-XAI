def check_normality_and_homogeneity(df):
    """Check normality and homogeneity for quantitative variables"""

    print("\n" + "=" * 60)
    print(" Checking Normality and Homogeneity Assumptions")
    print("=" * 60)

    target_col = 'Surfactant_Administered'

    # Quantitative variables
    quantitative_cols = [
        'Gestational_Age_Weeks', 'Gestational_Age_Days', 'Gestational_Age_Days_total', 'Maternal_Age',
        'Birth_Weight', 'Birth_Height', 'Head_Circumference',
        'Umbilical_pH', 'Base_Excess', 'FiO2'
    ]

    quantitative_cols = [col for col in quantitative_cols if col in df.columns]

    normality_results = {}

    for col in quantitative_cols:
        print(f"\n Variable: {col}")

        group_data = []
        group_labels = []
        normality_info = {}

        # Check normality for each group
        for group_val in sorted(df[target_col].unique()):
            data = df[df[target_col] == group_val][col].dropna().values

            if len(data) >= 3:  # Shapiro test requires at least 3 samples
                stat, p_value = shapiro(data)

                group_name = {
                    0: "No Surfactant",
                    1: "1 Administration",
                    2: "2 Administrations"
                }.get(group_val, f"Group {group_val}")

                is_normal = p_value > 0.05

                print(f"  {group_name:<20}: n={len(data):3d}, "
                      f"Shapiro p={p_value:.4f} ({'Normal' if is_normal else 'Not Normal'})")

                normality_info[group_val] = {
                    'n': len(data),
                    'is_normal': is_normal,
                    'p_value': p_value
                }

                group_data.append(data)
                group_labels.append(group_val)
            else:
                print(f"  Group {group_val}: Insufficient data (n={len(data)})")
                normality_info[group_val] = {
                    'n': len(data),
                    'is_normal': False,
                    'p_value': np.nan
                }

        # Check homogeneity of variances (only if at least 2 groups have data)
        is_homogeneous = True
        if len(group_data) >= 2:
            try:
                levene_stat, levene_p = levene(*group_data)
                is_homogeneous = levene_p > 0.05
                print(f"  Levene's test for homogeneity: p={levene_p:.4f} "
                      f"({'Homogeneous' if is_homogeneous else 'Not Homogeneous'})")
            except:
                print(f"  Levene's test: Could not compute")
                is_homogeneous = False

        normality_results[col] = {
            'normality_info': normality_info,
            'is_homogeneous': is_homogeneous,
            'all_normal': all([info['is_normal'] for info in normality_info.values()
                               if not np.isnan(info['p_value'])])
        }

    return normality_results


