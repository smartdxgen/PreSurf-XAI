    # Display key results
    print("\n" + "=" * 70)
    print(" Key Findings Summary:")
    print("=" * 70)

    # Show target distribution
    if target_summary is not None:
        print("\n Target Variable Distribution:")
        print(target_summary.to_string(index=False))

    # Show significant findings
    if stats_table is not None:
        print("\n Variables with Significant Differences (P < 0.05):")

        # Find rows with significant P-values
        significant_rows = []
        for _, row in stats_table.iterrows():
            p_val = row['P_value']
            if p_val != "N/A" and isinstance(p_val, (int, float)):
                if p_val < 0.05:
                    significant_rows.append(row)

        if significant_rows:
            print(f"\nFound {len(significant_rows)} variables with significant differences:")
            for row in significant_rows[:15]:  # Show first 15
                var = row['Variable']
                p_val = row['P_value']
                sig = row['Significant']
                var_type = row['Type']
                test_used = row['Test']

                # Determine significance level
                if "***" in sig:
                    sig_level = "p < 0.001"
                elif "**" in sig:
                    sig_level = "p < 0.01"
                elif "*" in sig:
                    sig_level = "p < 0.05"
                else:
                    sig_level = ""

                print(f"  • {var:<30} ({var_type}): p = {p_val:.4f} {sig_level} [{test_used}]")
        else:
            print("  No variables with significant differences found")

    print(f"\n Analysis Complete!")
    print(f" Output Files:")
    print(f"  • Complete_Analysis_Results.xlsx - All analysis tables")
    print(f"  • Analysis_Results/ folder - All visualizations")
    print(f"\n Total patients analyzed: {total_patients}")
    print(f" All rows preserved - no data removed")


