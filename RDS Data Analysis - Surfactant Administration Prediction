# =============================================================================

def identify_outliers(df):
    """Identify outliers using IQR method but DO NOT remove them"""

    print("\n" + "=" * 60)
    print("Identifying Outliers (No Rows Will Be Removed)")
    print("=" * 60)

    # Define quantitative columns to check for outliers
    quantitative_cols = [
        'Gestational_Age_Weeks', 'Gestational_Age_Days', 'Gestational_Age_Days_total', 'Maternal_Age',
        'Birth_Weight', 'Birth_Height', 'Head_Circumference',
        'Umbilical_pH', 'Base_Excess', 'FiO2'
    ]

    # Only use columns that exist in the dataframe
    columns_to_check = [col for col in quantitative_cols if col in df.columns]

    outlier_summary = []

    for col in columns_to_check:
        # Calculate IQR
        Q1 = df[col].quantile(0.25)
        Q3 = df[col].quantile(0.75)
        IQR = Q3 - Q1

        # Define outlier bounds
        lower_bound = Q1 - 1.5 * IQR
        upper_bound = Q3 + 1.5 * IQR

        # Count outliers
        outliers = df[(df[col] < lower_bound) | (df[col] > upper_bound)]
        outlier_count = len(outliers)

        if outlier_count > 0:
            outlier_pct = (outlier_count / len(df)) * 100
            print(f"  {col:<25}: {outlier_count:3d} outliers ({outlier_pct:.1f}%)")
            outlier_summary.append({
                'Variable': col,
                'Q1': round(Q1, 2),
                'Q3': round(Q3, 2),
                'IQR': round(IQR, 2),
                'Lower_Bound': round(lower_bound, 2),
                'Upper_Bound': round(upper_bound, 2),
                'Outlier_Count': outlier_count,
                'Outlier_Percentage': round(outlier_pct, 2)
            })

    print(f"\n Total rows: {len(df)}")
    print("No rows will be removed - keeping all data for analysis")

    return df, outlier_summary


